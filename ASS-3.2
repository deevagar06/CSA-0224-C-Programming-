//2. Find Maximum and Minimum in an Array (Using Pointers) 
#include <stdio.h> 
void findMaxMin(int *arr, int n) { 
int max = *arr; 
int min = *arr; 
for (int i = 1; i < n; i++) { 
if (*(arr + i) > max) 
max = *(arr + i); 
if (*(arr + i) < min) 
min = *(arr + i); 
} 
printf("Maximum = %d\n", max); 
printf("Minimum = %d\n", min); 
} 
int main() { 
int n; 
printf("Enter number of elements: "); 
scanf("%d", &n); 
int arr[n]; 
printf("Enter elements:\n"); 
for (int i = 0; i < n; i++) { 
scanf("%d", &arr[i]); 
} 
findMaxMin(arr, n); 
return 0; 
}
