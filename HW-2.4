//4) Magic Number 
#include <stdio.h> 
int main() { 
int num, sum; 
printf("Enter a number: "); 
scanf("%d", &num); 
while (num > 9) { 
sum = 0; 
while (num > 0) { 
sum += num % 10; 
num /= 10; 
} 
num = sum; 
} 
if (num == 1) 
printf("Magic Number\n"); 
else 
printf("Not a Magic Number\n"); 
return 0; 
}
