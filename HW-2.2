//2) Automorphic Number 
#include <stdio.h> 
#include <math.h> 
int main() { 
int num, square, digits = 0, temp; 
printf("Enter a number: "); 
scanf("%d", &num); 
square = num * num; 
temp = num; 
while (temp > 0) 
{ 
digits++; 
temp /= 10; 
} 
if (square % (int)pow(10, digits) == num) 
printf("Automorphic Number\n"); 
else 
printf("Not an Automorphic Number\n"); 
return 0; 
}
