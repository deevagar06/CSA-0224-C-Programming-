//5. Check Prime Number (Using Function) 
#include <stdio.h> 
void checkPrime(int num) { 
int flag = 0; 
if (num <= 1) { 
printf("Not a Prime Number\n"); 
return; 
} 
for (int i = 2; i <= num / 2; i++) { 
if (num % i == 0) { 
flag = 1; 
break; 
} 
} 
if (flag == 0) 
printf("Prime Number\n"); 
else 
printf("Not a Prime Number\n"); 
} 
int main() { 
int num; 
printf("Enter a number: "); 
scanf("%d", &num); 
checkPrime(num); 
return 0; 
}
