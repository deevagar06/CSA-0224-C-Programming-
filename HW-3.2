//2. Find All Occurrences of DNA Pattern 
#include <stdio.h> 
#include <string.h> 
int main() { 
char dna[200], pattern[50]; 
int i, j, found, count = 0; 
printf("Enter DNA sequence: "); 
scanf("%s", dna); 
printf("Enter DNA pattern: "); 
scanf("%s", pattern); 
int n = strlen(dna); 
int m = strlen(pattern); 
for(i = 0; i <= n - m; i++) { 
found = 1; 
for(j = 0; j < m; j++) { 
if(dna[i + j] != pattern[j]) { 
found = 0; 
break; 
} 
} 
if(found) { 
printf("Pattern found at position: %d\n", i + 1); 
count++; 
} 
} 
printf("Total occurrences: %d\n", count); 
return 0; 
}
