//3. Even Sum of Fibonacci Series Till N (Using Function) 
#include <stdio.h> 
void evenFibonacciSum(int n) { 
int a = 0, b = 1, c, sum = 0; 
while (a <= n) { 
if (a % 2 == 0) 
sum += a; 
c = a + b; 
a = b; 
b = c; 
} 
printf("Sum of Even Fibonacci numbers = %d\n", sum); 
} 
int main() { 
int n; 
printf("Enter limit: "); 
scanf("%d", &n); 
evenFibonacciSum(n); 
return 0; 
} 
