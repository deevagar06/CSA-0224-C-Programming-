//1. Check if Two Numbers are Equal (Using Function) 
#include <stdio.h> 
void checkEqual(int a, int b) { 
if (a == b) 
printf("Both numbers are Equal\n"); 
else 
printf("Numbers are Not Equal\n"); 
} 
int main() { 
int num1, num2; 
printf("Enter two numbers: "); 
scanf("%d %d", &num1, &num2); 
checkEqual(num1, num2); 
return 0; 
}
